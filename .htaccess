# Apache2 Configuration for Resort Reservation System
RewriteEngine On

# --- Security Headers ---
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; font-src 'self' https://cdnjs.cloudflare.com; img-src 'self' data:; connect-src 'self'"
    Header unset X-Powered-By
</IfModule>

# --- Block access to sensitive directories ---
# Replaced <DirectoryMatch> with RewriteRules (Safe for .htaccess)
RewriteRule ^(config|helpers|scripts|logs|tmp|database|output|vendor)/ - [F,L]

# --- Block access to sensitive files ---
<FilesMatch "\.(env|sql|md|log|sh|gitignore|htpasswd)$">
    Require all denied
</FilesMatch>

# Block access to dot files
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# --- Prevent Directory Listing ---
Options -Indexes

# --- Default Character Set ---
AddDefaultCharset UTF-8

# --- PHP Settings ---
<IfModule mod_php7.c>
    # Note: Use mod_php.c or mod_php7.c depending on your version
    php_flag display_errors Off
    php_flag log_errors On
    php_value error_log /home/davon/resort-reservation-system/logs/php_errors.log
</IfModule>

# --- Compression & Caching ---
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css application/json application/javascript
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 week"
</IfModule>
